# Comma-separated list of account tokens to run simultaneously.
DISCORD_TOKENS=token1,token2

# Comma-separated guild IDs to watch across all accounts.
# Leave empty to watch every guild each account has access to.
WATCHED_GUILDS=

# Channel ID to mirror edits and deletes into. Whichever account
# has access to this channel will post there.
LOG_CHANNEL_ID=

# Optional: legitimate Discord bot token for posting to LOG_CHANNEL_ID (recommended).
# The bot only needs Send Messages + Attach Files in the log channel.
# Takes priority over LOG_POSTER_TOKEN if both are set.
LOG_POSTER_BOT_TOKEN=

# Optional: secondary user account token for posting to LOG_CHANNEL_ID.
# This account does not need to be in any WATCHED_GUILDS.
# Used only when LOG_POSTER_BOT_TOKEN is not set.
# If neither is set, the first account in DISCORD_TOKENS that can see LOG_CHANNEL_ID posts instead.
LOG_POSTER_TOKEN=

# Channel-to-webhook mirror pairs, comma-separated: channel_id:webhook_url
# Repeat a channel_id with different URLs to fan out to multiple webhooks.
# Messages are queued in SQLite and posted with the original author's avatar and username.
MIRROR_CHANNELS=

# Whole-server mirror pairs, comma-separated: source_guild_id:dest_guild_id
# The bot auto-detects which token is in each guild and creates matching channels,
# categories, forums, and webhooks in the destination server on startup.
# The destination server is wiped and rebuilt from scratch on every startup.
# Channels and forums created in the source guild after startup are mirrored automatically too.
# Channels that are visible but unreadable (Forbidden) are placed in a '🔒 Unreadable'
# category and moved to their proper location automatically once permissions open up.
MIRROR_SERVERS=
